{
  "name": "idp",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone IDP application",
  "scripts": {
    "install:all": "npm install",
    "api:build": "npm --prefix apps/api-server run build",
    "api:start": "npm --prefix apps/api-server run start",
    "api:dev": "npm --prefix apps/api-server run dev",
    "ui:build": "npm --prefix apps/enterprise-ui run build",
    "ui:dev": "npm --prefix apps/enterprise-ui run dev",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build",
    "docs:preview": "npm --prefix docs-site run preview",
    "docs:validate": "node scripts/validate-docs.js",
    "test:report": "node scripts/report-test-results.mjs",
    "test:requirements": "node scripts/evaluate-docs-agentic-efficacy.js",
    "build": "npm run api:build && npm run ui:build && npm run docs:build",
    "verify:idp:standalone-baseline": "bash scripts/verify-idp-standalone-baseline.sh",
    "verify:idp:runtime-cutover-readiness": "bash scripts/verify-idp-runtime-cutover-readiness.sh",
    "ensure:idp:distributed-test-env": "bash deploy/iam-standalone/ensure-distributed-test-env.sh",
    "verify:idp:distributed-test-env": "bash deploy/iam-standalone/verify-distributed-test-env.sh",
    "verify:idp:runtime-distributed-bundle": "node scripts/verify-runtime-distributed-bundle.js",
    "verify:idp:saml-live-external-env": "node tests/integration/verify-bounded-saml-live-external-env.js",
    "verify:idp:saml-live-external-simplesamlphp": "bash deploy/iam-standalone/saml-live-external/verify-simplesamlphp.sh",
    "verify:idp:runtime-distributed-bundle-full": "npm run test:integration:runtime-distributed-bundle && npm run verify:idp:runtime-distributed-bundle",
    "verify:idp:sequence-a-bundle": "node scripts/verify-idp-sequence-a-bundle.js",
    "update:idp:sequence-a-bundle-status": "node scripts/update-idp-sequence-a-bundle-status.js",
    "render:idp:runtime-cutover-preflight": "node scripts/render-idp-runtime-cutover-preflight.js",
    "render:idp:runtime-distributed-bundle-summary": "node scripts/render-runtime-distributed-bundle-summary.js",
    "render:idp:sequence-a-status-matrix": "node scripts/render-idp-sequence-a-status-matrix.js",
    "scaffold:idp:runtime-cutover-evidence": "node scripts/scaffold-idp-runtime-cutover-evidence.js",
    "scaffold:idp:login-transaction-evidence": "node scripts/scaffold-idp-login-transaction-evidence.js",
    "scaffold:idp:ticket-evidence": "node scripts/scaffold-idp-ticket-evidence.js",
    "scaffold:idp:session-evidence": "node scripts/scaffold-idp-session-evidence.js",
    "scaffold:idp:issued-token-evidence": "node scripts/scaffold-idp-issued-token-evidence.js",
    "prepare:idp:runtime-cutover-evidence": "bash scripts/prepare-idp-runtime-cutover-evidence.sh",
    "prepare:idp:runtime-distributed-bundle-evidence": "bash scripts/prepare-runtime-distributed-bundle-evidence.sh",
    "prepare:idp:login-transaction-evidence": "bash scripts/prepare-idp-login-transaction-evidence.sh",
    "prepare:idp:ticket-evidence": "bash scripts/prepare-idp-runtime-cutover-evidence.sh tickets 2 'Tickets' docs/spec/plans/Headless_IAM_Ticket_Cutover_Checklist.md",
    "prepare:idp:session-evidence": "bash scripts/prepare-idp-runtime-cutover-evidence.sh sessions 3 'Sessions' docs/spec/plans/Headless_IAM_Session_Cutover_Checklist.md",
    "prepare:idp:issued-token-evidence": "bash scripts/prepare-idp-runtime-cutover-evidence.sh issued-tokens 4 'Issued tokens' docs/spec/plans/Headless_IAM_Issued_Token_Cutover_Checklist.md",
    "prepare:idp:sequence-a-evidence": "bash scripts/prepare-idp-sequence-a-evidence.sh",
    "verify:sdk:iam-contract": "node scripts/verify-sdk-iam-contract.js",
    "test:governance": "node scripts/verify-governance.js && npm run docs:validate && npm run test:requirements",
    "test:unit:api": "npm --prefix apps/api-server run test:coverage",
    "test:unit:ui": "npm --prefix apps/enterprise-ui run test:coverage",
    "test:unit": "npm run test:unit:api && npm run test:unit:ui",
    "test:integration:runtime-cutover-localstack": "node tests/integration/run-runtime-cutover-localstack.js",
    "test:integration:bounded-production-backup-restore-rehearsal": "node tests/integration/run-bounded-production-backup-restore-rehearsal.js",
    "test:integration:bounded-production-key-rotation-drill": "node tests/integration/run-bounded-production-key-rotation-drill.js",
    "test:integration:bounded-production-runtime-dependency-failure-drill": "node tests/integration/run-bounded-production-runtime-dependency-failure-drill.js",
    "test:integration:runtime-distributed-bundle": "node tests/integration/run-runtime-distributed-bundle.js",
    "test:integration:runtime-session-maintenance-localstack": "node tests/integration/run-runtime-session-maintenance-localstack.js",
    "test:integration:runtime-multi-instance-localstack": "node tests/integration/run-runtime-multi-instance-localstack.js",
    "test:integration:runtime-token-revocation-localstack": "node tests/integration/run-runtime-token-revocation-localstack.js",
    "test:integration:bounded-saml-sp-interoperability": "node tests/integration/run-bounded-saml-sp-interoperability.js",
    "test:integration:bounded-saml-sp-target-harness": "node tests/integration/run-bounded-saml-sp-target-harness.js",
    "test:integration:bounded-saml-sp-family-shape-calibration": "node tests/integration/run-bounded-saml-sp-family-shape-calibration.js",
    "test:integration:bounded-saml-sp-live-external-target": "node tests/integration/run-bounded-saml-sp-live-external-target.js",
    "start:idp:saml-live-external-simplesamlphp": "bash deploy/iam-standalone/saml-live-external/start-simplesamlphp.sh",
    "stop:idp:saml-live-external-simplesamlphp": "bash deploy/iam-standalone/saml-live-external/stop-simplesamlphp.sh",
    "test:journeys": "playwright test --config tests/journeys/playwright.config.ts",
    "test:performance": "node tests/performance/run-auth-smoke.js",
    "test:performance:runtime-auth": "node tests/performance/run-runtime-auth-bench.js",
    "test:performance:runtime-token": "node tests/performance/run-runtime-token-bench.js",
    "test:security": "npm run test:security:baseline && npm run test:security:authz",
    "test:security:baseline": "node tests/security/run-security-evaluation.js",
    "test:security:authz": "node tests/security/run-authz-evaluation.js",
    "test:security:token-abuse": "node tests/security/run-token-abuse-evaluation.js",
    "test:all": "npm run test:governance && npm run test:unit && npm run test:journeys && npm run test:performance && npm run test:security"
  },
  "workspaces": [
    "apps/*",
    "contracts/*",
    "docs-site"
  ],
  "overrides": {
    "@aws-sdk/xml-builder": "3.972.20",
    "fast-xml-parser": "5.7.2",
    "follow-redirects": "1.16.0",
    "postcss": "8.5.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "autocannon": "^8.0.0"
  }
}
