  "foundation_layer": {
    "description": "Core concepts that inform everything else",
    "mandatory_reading": true,
    "documents": {
      "constitution": {
        "path": "docs/foundation/constitution.md",
        "dependencies": [],
        "purpose": "Constitutional principles, governance, and foundational requirements"
      },
      "architecture": {
        "path": "docs/foundation/architecture.md",
        "dependencies": ["constitution"],
        "purpose": "System design overview and component relationships"
      },
      "security_model": {
        "path": "docs/foundation/security-model.md",
        "dependencies": ["constitution", "architecture"],
        "purpose": "Zero-trust security architecture and requirements"
      },
      "design_principles": {
        "path": "docs/foundation/design-principles.md",
        "dependencies": ["constitution", "architecture"],
        "purpose": "UX and development principles"
      }
    }
  },
  "specification_layer": {
    "description": "Technical requirements and detailed specifications",
    "organization": "by_domain",
    "domains": {
      "authentication": {
        "path": "docs/specs/authentication/",
        "key_document": "oauth-flows.md",
        "dependencies": ["foundation/architecture", "foundation/security-model"],
        "covers": ["OAuth 2.1", "OIDC", "SAML", "WebAuthn", "MFA"]
      },
      "federation": {
        "path": "docs/specs/federation/",
        "key_document": "external-idp.md",
        "dependencies": ["foundation/security-model"],
        "covers": ["External IdP integration", "Protocol mapping", "Trust management"]
      },
      "operations": {
        "path": "docs/specs/operations/",
        "key_document": "deployment-topology.md",
        "dependencies": ["foundation/architecture"],
        "covers": ["Deployment", "Monitoring", "Backup", "Recovery"]
      },
      "ui": {
        "path": "docs/specs/ui/",
        "key_document": "design-system.md",
        "dependencies": ["foundation/design-principles"],
        "covers": ["Design system", "Components", "Patterns"]
      },
      "api": {
        "path": "docs/specs/api/",
        "key_document": "openapi-spec.md",
        "dependencies": ["foundation/architecture"],
        "covers": ["REST APIs", "Webhooks", "SDK documentation"]
      }
    }
  },
  "implementation_layer": {
    "description": "Step-by-step procedures and how-to guides",
