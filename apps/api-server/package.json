{
  "name": "@idp/api-server",
  "version": "1.0.0",
  "description": "Standalone IDP API server",
  "main": "dist/server.js",
  "scripts": {
    "prestart": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch & nodemon dist/server.js",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:coverage": "jest --config jest.config.cjs --runInBand --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.300.0",
    "@aws-sdk/client-lambda": "^3.300.0",
    "@aws-sdk/client-s3": "^3.300.0",
    "@aws-sdk/lib-dynamodb": "^3.300.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^6.1.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.15.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0"
  }
}
