{
  "name": "@idp/enterprise-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone IDP web interface",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3004",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
