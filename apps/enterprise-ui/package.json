    "@radix-ui/react-tooltip": "^1.0.5",
    "@tanstack/react-query": "^4.24.6",
    "@turf/turf": "^6.5.0",
    "@types/leaflet": "^1.9.0",
    "@uiw/react-json-view": "^2.0.0-alpha.4",
    "axios": "^1.3.4",
    "clsx": "^1.2.1",
    "date-fns": "^2.29.3",
    "framer-motion": "^10.2.4",
    "leaflet": "^1.9.3",
