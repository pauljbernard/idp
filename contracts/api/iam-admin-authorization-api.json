{
  "openapi": "3.1.0",
  "info": {
    "title": "IAM Fine-Grained Admin Authorization API",
    "version": "1.0.0",
    "description": "Standalone headless IAM full-IDP Phase G endpoints for admin permission objects, policy bindings, evaluation audit, and restricted-admin impersonation."
  },
  "tags": [
    {
      "name": "IAM Admin Authorization",
      "description": "Fine-grained admin authorization registry and evaluation endpoints."
    }
  ],
  "paths": {
    "/api/v1/iam/admin-permissions": {
      "get": {
        "tags": ["IAM Admin Authorization"],
        "summary": "List IAM admin permissions",
        "responses": {
          "200": {
            "description": "Admin permissions resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPermissionsResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["IAM Admin Authorization"],
        "summary": "Create IAM admin permission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateIamAdminPermissionRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin permission created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPermissionRecord" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/admin-permissions/{permissionId}": {
      "put": {
        "tags": ["IAM Admin Authorization"],
        "summary": "Update IAM admin permission",
        "parameters": [
          { "name": "permissionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateIamAdminPermissionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin permission updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPermissionRecord" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/admin-policies": {
      "get": {
        "tags": ["IAM Admin Authorization"],
        "summary": "List IAM admin policies",
        "responses": {
          "200": {
            "description": "Admin policies resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPoliciesResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["IAM Admin Authorization"],
        "summary": "Create IAM admin policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateIamAdminPolicyRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin policy created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPolicyRecord" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/admin-policies/{policyId}": {
      "put": {
        "tags": ["IAM Admin Authorization"],
        "summary": "Update IAM admin policy",
        "parameters": [
          { "name": "policyId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateIamAdminPolicyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin policy updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminPolicyRecord" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/admin-evaluations": {
      "get": {
        "tags": ["IAM Admin Authorization"],
        "summary": "List IAM admin authorization evaluations",
        "responses": {
          "200": {
            "description": "Evaluation audit resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamAdminEvaluationsResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/users/{userId}/impersonate": {
      "post": {
        "tags": ["IAM Admin Authorization"],
        "summary": "Start IAM user impersonation",
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "201": {
            "description": "Impersonation session issued.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamLoginResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IamAdminPermissionRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "domain": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } },
          "scope_kind": { "type": "string" },
          "managed_user_ids": { "type": "array", "items": { "type": "string" } },
          "managed_group_ids": { "type": "array", "items": { "type": "string" } },
          "managed_role_ids": { "type": "array", "items": { "type": "string" } },
          "managed_client_ids": { "type": "array", "items": { "type": "string" } },
          "synthetic": { "type": "boolean" },
          "source_delegated_admin_id": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "created_by_user_id": { "type": "string" },
          "updated_by_user_id": { "type": "string" }
        }
      },
      "IamAdminPermissionsResponse": {
        "type": "object",
        "properties": {
          "generated_at": { "type": "string", "format": "date-time" },
          "permissions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IamAdminPermissionRecord" }
          },
          "count": { "type": "number" }
        }
      },
      "CreateIamAdminPermissionRequest": {
        "type": "object",
        "required": ["realm_id", "name", "summary", "domain", "actions"],
        "properties": {
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "domain": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } },
          "scope_kind": { "type": "string" },
          "managed_user_ids": { "type": "array", "items": { "type": "string" } },
          "managed_group_ids": { "type": "array", "items": { "type": "string" } },
          "managed_role_ids": { "type": "array", "items": { "type": "string" } },
          "managed_client_ids": { "type": "array", "items": { "type": "string" } }
        }
      },
      "UpdateIamAdminPermissionRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } },
          "scope_kind": { "type": "string" },
          "managed_user_ids": { "type": "array", "items": { "type": "string" } },
          "managed_group_ids": { "type": "array", "items": { "type": "string" } },
          "managed_role_ids": { "type": "array", "items": { "type": "string" } },
          "managed_client_ids": { "type": "array", "items": { "type": "string" } }
        }
      },
      "IamAdminPolicyRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "principal_kind": { "type": "string" },
          "principal_id": { "type": "string" },
          "principal_label": { "type": "string" },
          "permission_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" },
          "synthetic": { "type": "boolean" },
          "source_delegated_admin_id": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "created_by_user_id": { "type": "string" },
          "updated_by_user_id": { "type": "string" }
        }
      },
      "IamAdminPoliciesResponse": {
        "type": "object",
        "properties": {
          "generated_at": { "type": "string", "format": "date-time" },
          "policies": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IamAdminPolicyRecord" }
          },
          "count": { "type": "number" }
        }
      },
      "CreateIamAdminPolicyRequest": {
        "type": "object",
        "required": ["realm_id", "name", "summary", "principal_kind", "principal_id", "principal_label", "permission_ids"],
        "properties": {
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "principal_kind": { "type": "string" },
          "principal_id": { "type": "string" },
          "principal_label": { "type": "string" },
          "permission_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" }
        }
      },
      "UpdateIamAdminPolicyRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "principal_label": { "type": "string" },
          "permission_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" }
        }
      },
      "IamAdminEvaluationRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "realm_id": { "type": "string" },
          "actor_user_id": { "type": "string" },
          "actor_username": { "type": "string" },
          "actor_group_ids": { "type": "array", "items": { "type": "string" } },
          "actor_role_ids": { "type": "array", "items": { "type": "string" } },
          "domain": { "type": "string" },
          "action": { "type": "string" },
          "target_resource_id": { "type": ["string", "null"] },
          "target_resource_label": { "type": ["string", "null"] },
          "allowed": { "type": "boolean" },
          "reason": { "type": "string" },
          "route": { "type": "string" },
          "method": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "IamAdminEvaluationsResponse": {
        "type": "object",
        "properties": {
          "generated_at": { "type": "string", "format": "date-time" },
          "evaluations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IamAdminEvaluationRecord" }
          },
          "count": { "type": "number" }
        }
      },
      "IamLoginResponse": {
        "type": "object",
        "properties": {
          "realm_id": { "type": "string" },
          "next_step": { "type": "string" },
          "login_transaction_id": { "type": "string" },
          "session_id": { "type": ["string", "null"] },
          "post_login_destination": { "type": ["string", "null"] }
        }
      }
    }
  }
}
