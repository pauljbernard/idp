{
  "openapi": "3.1.0",
  "info": {
    "title": "Standalone IAM Service Accounts API",
    "version": "1.0.0",
    "description": "Standalone headless IAM service-account endpoints for machine principal visibility and RBAC assignment."
  },
  "tags": [
    {
      "name": "IAM Service Accounts",
      "description": "Standalone headless IAM machine principal visibility and RBAC management."
    }
  ],
  "paths": {
    "/api/v1/iam/service-accounts": {
      "get": {
        "tags": ["IAM Service Accounts"],
        "summary": "List IAM service accounts",
        "parameters": [
          { "name": "realm_id", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "IAM service accounts resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamServiceAccountsResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/service-accounts/{serviceAccountId}": {
      "put": {
        "tags": ["IAM Service Accounts"],
        "summary": "Update IAM service account RBAC assignment",
        "parameters": [
          {
            "name": "serviceAccountId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateIamServiceAccountRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "IAM service account updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamServiceAccountRecord" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IamServiceAccountStatus": { "type": "string", "enum": ["ACTIVE", "DISABLED"] },
      "IamServiceAccountRecord": {
        "type": "object",
        "required": ["id", "realm_id", "client_id", "username", "role_ids", "status", "synthetic", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "realm_id": { "type": "string" },
          "client_id": { "type": "string" },
          "username": { "type": "string" },
          "role_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "$ref": "#/components/schemas/IamServiceAccountStatus" },
          "synthetic": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "UpdateIamServiceAccountRequest": {
        "type": "object",
        "properties": {
          "role_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": { "$ref": "#/components/schemas/IamServiceAccountStatus" }
        }
      },
      "IamServiceAccountsResponse": {
        "type": "object",
        "required": ["generated_at", "service_accounts", "count"],
        "properties": {
          "generated_at": { "type": "string", "format": "date-time" },
          "service_accounts": { "type": "array", "items": { "$ref": "#/components/schemas/IamServiceAccountRecord" } },
          "count": { "type": "integer" }
        }
      }
    }
  }
}
