{
  "openapi": "3.1.0",
  "info": {
    "title": "Standalone IAM Roles API",
    "version": "1.0.0",
    "description": "Phase 1 standalone IAM RBAC role administration endpoints."
  },
  "tags": [
    {
      "name": "IAM Roles",
      "description": "Standalone headless IAM role administration."
    }
  ],
  "paths": {
    "/api/v1/iam/roles": {
      "get": {
        "tags": ["IAM Roles"],
        "summary": "List IAM roles",
        "parameters": [
          { "name": "realm_id", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "kind", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/IamRoleKind" } }
        ],
        "responses": {
          "200": {
            "description": "IAM roles resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamRolesResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["IAM Roles"],
        "summary": "Create IAM role",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateIamRoleRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "IAM role created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamRoleRecord" }
              }
            }
          }
        }
      }
    },
    "/api/v1/iam/roles/{roleId}": {
      "put": {
        "tags": ["IAM Roles"],
        "summary": "Update IAM role",
        "parameters": [
          { "name": "roleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateIamRoleRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "IAM role updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IamRoleRecord" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IamRoleKind": { "type": "string", "enum": ["REALM_ROLE", "CLIENT_ROLE", "COMPOSITE_ROLE"] },
      "IamRoleStatus": { "type": "string", "enum": ["ACTIVE", "ARCHIVED"] },
      "IamRoleRecord": {
        "type": "object",
        "required": ["id", "realm_id", "name", "summary", "kind", "status", "synthetic", "client_id", "composite_role_ids", "created_at", "updated_at", "created_by_user_id", "updated_by_user_id"],
        "properties": {
          "id": { "type": "string" },
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "kind": { "$ref": "#/components/schemas/IamRoleKind" },
          "status": { "$ref": "#/components/schemas/IamRoleStatus" },
          "synthetic": { "type": "boolean" },
          "client_id": { "type": ["string", "null"] },
          "composite_role_ids": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "created_by_user_id": { "type": "string" },
          "updated_by_user_id": { "type": "string" }
        }
      },
      "IamRolesResponse": {
        "type": "object",
        "required": ["generated_at", "roles", "count"],
        "properties": {
          "generated_at": { "type": "string", "format": "date-time" },
          "roles": { "type": "array", "items": { "$ref": "#/components/schemas/IamRoleRecord" } },
          "count": { "type": "integer" }
        }
      },
      "CreateIamRoleRequest": {
        "type": "object",
        "required": ["realm_id", "name"],
        "properties": {
          "realm_id": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "kind": { "$ref": "#/components/schemas/IamRoleKind" },
          "client_id": { "type": ["string", "null"] },
          "composite_role_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "$ref": "#/components/schemas/IamRoleStatus" }
        }
      },
      "UpdateIamRoleRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "client_id": { "type": ["string", "null"] },
          "composite_role_ids": { "type": "array", "items": { "type": "string" } },
          "status": { "$ref": "#/components/schemas/IamRoleStatus" }
        }
      }
    }
  }
}
