# Standalone IDP bootstrap example for a local AWS clone or development AWS account.

NODE_ENV=development
PORT=4000
IDP_UI_BASE_URL=http://localhost:3004

AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Distributed runtime persistence.
IDP_PLATFORM_PERSISTENCE_BACKEND=dynamodb-s3
IDP_PLATFORM_STATE_DYNAMODB_TABLE=idp-platform-state-local
IDP_IAM_RUNTIME_DDB_TABLE=idp-iam-runtime-local
IDP_PLATFORM_DURABLE_S3_BUCKET=idp-durable-local
IDP_PLATFORM_DYNAMODB_ENDPOINT=http://localhost:4566
IDP_PLATFORM_S3_ENDPOINT=http://localhost:4566

# Runtime entity cutover. Start with dual-write only, then enable read-v2 after burn-in.
IDP_DDB_RUNTIME_DUAL_WRITE=false
IDP_DDB_RUNTIME_READ_V2=false

# Distributed throttling.
IDP_RATE_LIMIT_BACKEND=dynamodb
IDP_RATE_LIMIT_DYNAMODB_TABLE=idp-rate-limit-local
IDP_DYNAMODB_ENDPOINT=http://localhost:4566
IDP_S3_ENDPOINT=http://localhost:4566

# Broader standalone deployment contract.
IAM_REALM_TABLE_NAME=idp-iam-realm-local
IAM_ARTIFACT_BUCKET=idp-iam-artifact-local
IAM_KMS_KEY_ARN=arn:aws:kms:us-east-1:000000000000:key/idp-local-placeholder
IAM_SECRETS_PREFIX=/idp/local
IAM_EVENT_BUS_NAME=idp-local-bus
IAM_BOOTSTRAP_ADMIN_EMAIL=admin@idp.local
